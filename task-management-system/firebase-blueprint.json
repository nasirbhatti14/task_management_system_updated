{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "created_at"]
    },
    "Task": {
      "title": "Task",
      "description": "A task created by a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed"] },
        "due_date": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "status", "created_at"]
    },
    "TaskShare": {
      "title": "Task Share",
      "description": "A record of a task shared with another user",
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "user_id": { "type": "string" },
        "shared_by": { "type": "string" },
        "owner_username": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["task_id", "user_id", "shared_by", "created_at"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "message": { "type": "string" },
        "is_read": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "message", "is_read", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks"
    },
    "/task_shares/{shareId}": {
      "schema": { "$ref": "#/entities/TaskShare" },
      "description": "Task shares"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Notifications"
    }
  }
}
